---
// src/pages/insights.astro
// 2026-05-17T00:00:00Z

import { readFile } from "node:fs/promises";
import Layout from "@layouts/BaseLayout.astro";
import type { ResultsFile } from "../types/index";

const meta = {
	title: "Version Insights — Astro Showcase | What CMS? How Fast?",
	description: "Astro and Starlight version distribution, submission trends, and adoption patterns across the full Astro showcase.",
};

const raw: ResultsFile = JSON.parse(
	await readFile("src/data/cms-results.json", "utf8"),
);
const results = raw.results;

// ── Version distribution (all Astro-detected sites) ─────────────────────────
const VERSION_COLOURS: Record<string, string> = {
	v1: "#f87171", // red
	v2: "#fb923c", // orange
	v3: "#fbbf24", // amber
	v4: "#34d399", // emerald
	v5: "#60a5fa", // blue
	v6: "#a78bfa", // violet
	v7: "#f472b6", // pink
	unknown: "#94a3b8", // slate
};

const versionCounts: Record<string, number> = {};
for (const site of results) {
	if (!site.astroDetected) continue;
	const major = site.astroVersion
		? `v${site.astroVersion.split(".")[0]}`
		: "unknown";
	versionCounts[major] = (versionCounts[major] ?? 0) + 1;
}
const versionLabels = Object.keys(versionCounts).sort((a, b) => {
	if (a === "unknown") return 1;
	if (b === "unknown") return -1;
	return a.localeCompare(b, undefined, { numeric: true });
});
const versionData = versionLabels.map((k) => versionCounts[k]);
const versionColors = versionLabels.map((k) => VERSION_COLOURS[k] ?? "#94a3b8");
const totalDetected = results.filter((r) => r.astroDetected).length;

// ── Submission year × Astro major (stacked bar) ──────────────────────────────
const MAJORS = ["v1", "v2", "v3", "v4", "v5", "v6", "v7"];
const yearMajor: Record<number, Record<string, number>> = {};

for (const site of results) {
	if (!site.astroDetected || !site.astroVersion || !site.dateAdded) continue;
	const year = new Date(site.dateAdded).getFullYear();
	const major = `v${site.astroVersion.split(".")[0]}`;
	if (!yearMajor[year]) yearMajor[year] = {};
	yearMajor[year][major] = (yearMajor[year][major] ?? 0) + 1;
}
const years = Object.keys(yearMajor).sort();

const stackedDatasets = MAJORS.map((major) => ({
	label: major,
	data: years.map((y) => yearMajor[Number(y)]?.[major] ?? 0),
	backgroundColor: VERSION_COLOURS[major] ?? "#94a3b8",
}));

// ── Starlight version distribution ───────────────────────────────────────────

// Group Starlight versions into recency bands (latest = v0.39.x as of May 2026)
// Bands: v1+, v0.37–v0.39 (recent), v0.32–v0.36 (mid), v0.25–v0.31, older / unknown
function starlightBand(version: string | null): string {
	if (!version) return "unknown";
	const [major, minor] = version.split(".").map(Number);
	if (major >= 1) return "v1+";
	if (minor >= 37) return "v0.37–v0.39 (recent)";
	if (minor >= 32) return "v0.32–v0.36";
	if (minor >= 28) return "v0.28–v0.31";
	if (minor >= 25) return "v0.25–v0.27";
	return "v0.24 and older";
}

const BAND_ORDER = [
	"v1+",
	"v0.37–v0.39 (recent)",
	"v0.32–v0.36",
	"v0.28–v0.31",
	"v0.25–v0.27",
	"v0.24 and older",
	"unknown",
];
const BAND_COLOURS: Record<string, string> = {
	"v1+": "#34d399", // emerald
	"v0.37–v0.39 (recent)": "#60a5fa", // blue
	"v0.32–v0.36": "#a78bfa", // violet
	"v0.28–v0.31": "#fbbf24", // amber
	"v0.25–v0.27": "#fb923c", // orange
	"v0.24 and older": "#f87171", // red
	unknown: "#94a3b8", // slate
};

const starlightCounts: Record<string, number> = {};
for (const site of results) {
	if (site.cms !== "Starlight") continue;
	const band = starlightBand(site.starlightVersion);
	starlightCounts[band] = (starlightCounts[band] ?? 0) + 1;
}
const starlightLabels = BAND_ORDER.filter((b) => starlightCounts[b]);
const starlightData = starlightLabels.map((k) => starlightCounts[k]);
const starlightColors = starlightLabels.map((k) => BAND_COLOURS[k]);
const totalStarlight = results.filter((r) => r.cms === "Starlight").length;

// ── Summary stats ─────────────────────────────────────────────────────────────
const current = (versionCounts["v6"] ?? 0) + (versionCounts["v7"] ?? 0);
const legacy =
	(versionCounts["v1"] ?? 0) +
	(versionCounts["v2"] ?? 0) +
	(versionCounts["v3"] ?? 0);
---

<Layout metaData={meta}>
  <div class="wrapper flow"> 
    <header class="page-header flow">
    <h1>Insights</h1>
    <p class="page-lead">Version distribution and submission trends across {totalDetected.toLocaleString()} Astro-detected sites.</p>
  </header>
    <div class="stats-row">
      <div class="stat-card">
        <span class="stat-value violet">{(versionCounts["v5"] ?? 0) + (versionCounts["v6"] ?? 0) + (versionCounts["v7"] ?? 0)}</span>
        <span class="stat-label">On v5 or later</span>
      </div>
      <div class="stat-card">
        <span class="stat-value green">{current}</span>
        <span class="stat-label">On v6 / v7 (current)</span>
      </div>
      <div class="stat-card">
        <span class="stat-value amber">{legacy}</span>
        <span class="stat-label">Still on v1–v3</span>
      </div>
      <div class="stat-card">
        <span class="stat-value slate">{versionCounts["unknown"] ?? 0}</span>
        <span class="stat-label">Unknown detected</span>
      </div>
    </div>

    <div class="charts-grid">
      <div class="chart-card">
        <h2>Astro version distribution</h2>
        <p class="chart-desc">Which major version is each site currently running?</p>
        <div class="doughnut-wrap">
          <canvas id="versionChart"></canvas>
        </div>
      </div>

      <div class="chart-card">
        <h2>Starlight version distribution</h2>
        <p class="chart-desc">Which major Starlight version are the {totalStarlight} Starlight sites running?</p>
        <div class="doughnut-wrap">
          <canvas id="starlightChart"></canvas>
        </div>
      </div>

      <div class="chart-card">
        <h2>Submission year vs Astro version in use</h2>
        <p class="chart-desc">Sites grouped by the year they were added to the showcase, coloured by the Astro major version they are currently running.</p>
        <div class="bar-wrap">
          <canvas id="yearChart"></canvas>
        </div>
      </div>
    </div>
  </div>
</Layout>

<!-- Pass server data to client via JSON script tag -->
<script id="insights-data" type="application/json" set:html={JSON.stringify({ versionLabels, versionData, versionColors, years, stackedDatasets, starlightLabels, starlightData, starlightColors }).replace(/<\/script>/gi, "<\\/script>")} />

<script>
  import { Chart, ArcElement, DoughnutController, BarElement, BarController, CategoryScale, LinearScale, Legend, Tooltip } from "chart.js";
  Chart.register(ArcElement, DoughnutController, BarElement, BarController, CategoryScale, LinearScale, Legend, Tooltip);

  function initCharts() {
    const dataEl = document.getElementById("insights-data");
    if (!dataEl) return;

    // Destroy any existing chart instances on these canvases before re-creating
    for (const id of ["versionChart", "starlightChart", "yearChart"]) {
      const existing = Chart.getChart(id);
      if (existing) existing.destroy();
    }

    const { versionLabels, versionData, versionColors, years, stackedDatasets, starlightLabels, starlightData, starlightColors } = JSON.parse(dataEl.textContent ?? "{}");

    const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const textColor = isDark ? "#94a3b8" : "#64748b";
    const gridColor = isDark ? "rgba(255,255,255,0.06)" : "rgba(0,0,0,0.06)";
    const borderColor = isDark ? "#1e293b" : "#ffffff";

    // Doughnut — version distribution
    new Chart(document.getElementById("versionChart") as HTMLCanvasElement, {
      type: "doughnut",
      data: {
        labels: versionLabels,
        datasets: [{
          data: versionData,
          backgroundColor: versionColors,
          borderWidth: 2,
          borderColor,
          hoverOffset: 8,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: "62%",
        plugins: {
          legend: {
            position: "right",
            labels: { color: textColor, padding: 16, font: { size: 13 } },
          },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const total = (ctx.dataset.data as number[]).reduce((a, b) => a + b, 0);
                const pct = total > 0 ? ((ctx.parsed / total) * 100).toFixed(1) : "0.0";
                return ` ${ctx.label}: ${ctx.parsed.toLocaleString()} sites (${pct}%)`;
              },
            },
          },
        },
      },
    });

    // Doughnut — Starlight version distribution
    new Chart(document.getElementById("starlightChart") as HTMLCanvasElement, {
      type: "doughnut",
      data: {
        labels: starlightLabels,
        datasets: [{
          data: starlightData,
          backgroundColor: starlightColors,
          borderWidth: 2,
          borderColor,
          hoverOffset: 8,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: "62%",
        plugins: {
          legend: {
            position: "right",
            labels: { color: textColor, padding: 16, font: { size: 13 } },
          },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const total = (ctx.dataset.data as number[]).reduce((a, b) => a + b, 0);
                const pct = total > 0 ? ((ctx.parsed / total) * 100).toFixed(1) : "0.0";
                return ` ${ctx.label}: ${ctx.parsed.toLocaleString()} sites (${pct}%)`;
              },
            },
          },
        },
      },
    });

    // Stacked bar — year × version
    new Chart(document.getElementById("yearChart") as HTMLCanvasElement, {
      type: "bar",
      data: { labels: years, datasets: stackedDatasets },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          x: { stacked: true, ticks: { color: textColor }, grid: { color: gridColor } },
          y: { stacked: true, ticks: { color: textColor }, grid: { color: gridColor } },
        },
        plugins: {
          legend: {
            position: "bottom",
            labels: { color: textColor, padding: 12, font: { size: 12 } },
          },
          tooltip: {
            callbacks: {
              label: (ctx) => ` ${ctx.dataset.label}: ${ctx.parsed.y} sites`,
            },
          },
        },
      },
    });
  }

  initCharts();
  document.addEventListener("astro:page-load", initCharts);
</script>

<style>
  /* Value colour variants — semantic meaning, not rating */
  .stat-value.violet { color: var(--violet-6); }
  .stat-value.green  { color: var(--green-6); }
  .stat-value.amber  { color: var(--orange-5); }
  .stat-value.slate  { color: var(--gray-5); }

  .charts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-l);
  }

  .chart-card {
    background: var(--color-surface);
    border: 1px solid var(--gray-2);
    border-radius: var(--space-3xs);
    padding: var(--space-m);
  }
  .chart-card h2 {
    font-size: var(--step-0);
    font-weight: 600;
    margin-block-end: var(--space-3xs);
  }
  .chart-desc {
    font-size: var(--step--2);
    color: var(--color-text-subtle);
    margin-block-end: var(--space-m);
  }
  .doughnut-wrap { max-width: 780px; margin-inline: auto; }
  .bar-wrap { width: 100%; }
</style>
