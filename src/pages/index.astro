---
// src/pages/index.astro
// 2026-05-17T00:00:00Z

import ShowcasePagination from "@components/showcase/ShowcasePagination.astro";
import ShowcaseTable from "@components/showcase/ShowcaseTable.astro";
import ShowcaseToolbar from "@components/showcase/ShowcaseToolbar.astro";
import { siteMetadata } from "@config/siteMetadata";
import Layout from "@layouts/BaseLayout.astro";
import type { ResultsFile } from "../types/index";

const PAGE_SIZE = siteMetadata.showcasePageSize ?? 50;

const meta = {
	title: "Astro Showcase — CMS Detector",
	description: "Which CMS (if any) powers each site in the Astro showcase?",
};

let data: ResultsFile | null = null;
try {
	const raw = await import("../data/cms-results.json");
	data = raw.default as ResultsFile;
} catch {
	// data file not yet generated — show empty state
}

const results = data?.results ?? [];
const total = results.length;

const CMS_TYPES = new Set([
	"headless-cms",
	"page-builder",
	"full-site",
	"framework",
	"static-gen",
]);
const cmsCounts = new Map<string, number>();
for (const r of results) {
	if (!CMS_TYPES.has(r.cmsType)) continue;
	cmsCounts.set(r.cms, (cmsCounts.get(r.cms) ?? 0) + 1);
}
const sorted = [...cmsCounts.entries()].sort((a, b) => b[1] - a[1]);

const detected = results.filter((r) => CMS_TYPES.has(r.cmsType)).length;
const errors = results.filter((r) => r.cms === "Error").length;
const astroConfirmed = results.filter((r) => r.astroDetected).length;
const noLongerAstro = results.filter(
	(r) => !r.astroDetected && r.cms !== "Error" && r.cms !== "Blocked",
).length;
const starlightCount = results.filter((r) => r.cms === "Starlight").length;
const frameworkCount = results.filter((r) => r.cmsType === "framework").length;
const forwardedCount = results.filter((r) => r.cms === "Forwarded").length;
const parkedCount = results.filter(
	(r) => r.cmsType === "parked" && r.cms !== "Forwarded",
).length;
---

<Layout metaData={meta}>
  <main class="wrapper flow" style="--flow-space: var(--space-l)">

    <header class="page-header flow">
      <h1>Astro Showcase <span class="muted">CMS Detector</span></h1>
      <p class="about-lead">
        Every site featured on the <a href="https://astro.build/showcase/" target="_blank" rel="noopener noreferrer">official Astro Showcase</a> — automatically scanned to detect which CMS (if any) is powering it, and which version of Astro it's running.
      </p>
   
      <p class="submit-cta">
        <a href="https://github.com/withastro/roadmap/discussions/521" target="_blank" rel="noopener noreferrer">Submit your site to the Astro Showcase →</a>
      </p>
      <details class="about-details">
        <summary>About this data</summary>
        <div class="about-body">
          <p>Detection is automated: each site is fetched and inspected for Astro fingerprints (script filenames, meta generators, HTTP headers) and CMS signals (API endpoints, script patterns, DNS records). It's accurate but not infallible.</p>
          <p><strong>Caveats:</strong> some sites block scrapers, redirect away from their Astro front-end, or don't expose version signals. Sites marked <em>"Astro not detected"</em> may have migrated to another platform, may be behind a CDN that strips headers, or simply couldn't be reached at scan time. Confidence badges (high / medium / low) reflect how many signals were found.</p>
        </div>
      </details>  
       {data ? (
        <p class="meta-line">
          {total.toLocaleString()} sites scanned &middot; generated {new Date(data.generated).toLocaleDateString("en-GB", { dateStyle: "medium" })}
        </p>
      ) : (
        <p class="notice">No data yet — run <code>pnpm detect</code> to scan the showcase.</p>
      )}
    </header>

    {data && (
      <>
        <section class="stats-grid" aria-label="Summary">
          <div class="stat-card">
            <span class="stat-value">{total.toLocaleString()}</span>
            <span class="stat-label">Sites scanned</span>
          </div>
          <div class="stat-card stat-card--astro">
            <span class="stat-value">{astroConfirmed}</span>
            <span class="stat-label">Astro confirmed</span>
          </div>
          <div class="stat-card stat-card--migrated">
            <span class="stat-value">{noLongerAstro}</span>
            <span class="stat-label">Astro not detected</span>
          </div>
          <div class="stat-card stat-card--detected">
            <span class="stat-value">{detected}</span>
            <span class="stat-label">Sites with CMS detected</span>
          </div>
          <div class="stat-card stat-card--parked">
            <span class="stat-value">{forwardedCount + parkedCount}</span>
            <span class="stat-label">Parked or forwarded</span>
          </div>
          <div class="stat-card stat-card--error">
            <span class="stat-value">{errors}</span>
            <span class="stat-label">Fetch errors</span>
          </div>
        </section>

        <section class="breakdown flow" aria-label="CMS breakdown">
          <h2>Breakdown</h2>
          <ul class="bar-list" role="list">
            {sorted.map(([cms, count], i) => (
              <li class="bar-item" data-index={i + 1}>
                <button class="bar-filter-btn" data-cms={cms} type="button">
                  <span class="bar-label">
                    <span class="bar-index">{i + 1}</span>
                    <span class="cms-badge">{cms}</span>
                  </span>
                  <span class="bar-track" aria-hidden="true">
                    <span class="bar-fill" style={`width: ${((count / total) * 100).toFixed(1)}%`}></span>
                  </span>
                  <span class="bar-count">{count}</span>
                </button>
              </li>
            ))}
          </ul>
        </section>

        <section class="results-section flow" aria-label="Site results">
          <ShowcaseToolbar
            starlightCount={starlightCount}
            frameworkCount={frameworkCount}
            forwardedCount={forwardedCount}
            parkedCount={parkedCount}
            noLongerAstro={noLongerAstro}
          />

          <p class="results-count" id="results-count" aria-live="polite">
            Showing {total} sites
          </p>

          <ShowcaseTable results={results} pageSize={PAGE_SIZE} />
          <ShowcasePagination />
        </section>
      </>
    )}
  </main>
</Layout>

<script is:inline>
  function initDetector() {
    const table = document.getElementById("results-table");
    const tbody = table?.querySelector("tbody");
    const searchInput = document.getElementById("search");
    const clearBtn = document.getElementById("clear-filter");
    const astroFilterBtn = document.getElementById("astro-filter");
    const starlightFilterBtn = document.getElementById("starlight-filter");
    const frameworkFilterBtn = document.getElementById("framework-filter");
    const forwardedFilterBtn = document.getElementById("forwarded-filter");
    const parkedFilterBtn = document.getElementById("parked-filter");
    const countEl = document.getElementById("results-count");
    const paginationEl = document.getElementById("pagination");
    if (!tbody || !searchInput || !table) return;

    const PAGE_SIZE = parseInt(table.dataset.pageSize ?? "50", 10);
    const allRows = Array.from(tbody.querySelectorAll("tr"));

    let activeCmsFilter = null;
    let activeCmsTypeFilter = null;
    let forwardedOnly = false;
    let parkedOnly = false;
    let noAstroOnly = false;
    let sortCol = null;
    let sortAsc = true;
    let currentPage = 1;

    // ── Sorting ──────────────────────────────────────────────────────────────

    function getSortValue(row, col) {
      switch (col) {
        case "title":   return row.dataset.title ?? "";
        case "cms":     return row.dataset.cms?.toLowerCase() ?? "";
        case "cmstype": return row.dataset.cmstype ?? "";
        default:        return "";
      }
    }

    // Parse "4.10.2" → [4, 10, 2] for correct numeric semver comparison
    function parseVersion(v) {
      if (!v) return null;
      return v.split(".").map(n => parseInt(n, 10) || 0);
    }

    function compareVersions(a, b) {
      const av = parseVersion(a);
      const bv = parseVersion(b);
      if (!av && !bv) return 0;
      if (!av) return 1;   // no version sorts last
      if (!bv) return -1;
      for (let i = 0; i < Math.max(av.length, bv.length); i++) {
        const diff = (av[i] ?? 0) - (bv[i] ?? 0);
        if (diff !== 0) return diff;
      }
      return 0;
    }

    function sortRows(rows) {
      if (!sortCol) return rows;
      return [...rows].sort((a, b) => {
        if (sortCol === "astro") {
          const cmp = compareVersions(a.dataset.astroversion, b.dataset.astroversion);
          return sortAsc ? cmp : -cmp;
        }
        const av = getSortValue(a, sortCol);
        const bv = getSortValue(b, sortCol);
        if (!av && bv) return 1;
        if (av && !bv) return -1;
        if (!av && !bv) return 0;
        const cmp = av.localeCompare(bv, undefined, { numeric: true });
        return sortAsc ? cmp : -cmp;
      });
    }

    document.querySelectorAll(".sortable").forEach((th) => {
      th.addEventListener("click", () => {
        const col = th.dataset.col;
        if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
        document.querySelectorAll(".sortable").forEach((h) => {
          h.classList.remove("sort-asc", "sort-desc");
          h.querySelector(".sort-icon").textContent = "⇅";
        });
        th.classList.add(sortAsc ? "sort-asc" : "sort-desc");
        th.querySelector(".sort-icon").textContent = sortAsc ? "▲" : "▼";
        currentPage = 1;
        applyView();
      });
    });

    // ── Filtering ─────────────────────────────────────────────────────────────

    function getFilteredRows() {
      const query = searchInput.value.toLowerCase();
      return allRows.filter((row) => {
        const matchesCms      = !activeCmsFilter     || row.dataset.cms === activeCmsFilter;
        const matchesCmsType  = !activeCmsTypeFilter || row.dataset.cmstype === activeCmsTypeFilter;
        const matchesForwarded = !forwardedOnly || row.dataset.cms === "Forwarded";
        const matchesParked   = !parkedOnly || (row.dataset.cmstype === "parked" && row.dataset.cms !== "Forwarded");
        const matchesSearch   = !query || row.dataset.title.includes(query) || row.dataset.url.includes(query);
        const matchesAstro    = !noAstroOnly || row.dataset.astro === "false";
        return matchesCms && matchesCmsType && matchesForwarded && matchesParked && matchesSearch && matchesAstro;
      });
    }

    // ── Pagination ────────────────────────────────────────────────────────────

    function renderPagination(total, page) {
      if (!paginationEl) return;
      const totalPages = Math.ceil(total / PAGE_SIZE);
      if (totalPages <= 1) { paginationEl.innerHTML = ""; return; }

      const items = [];
      const numBtn = (p, active) =>
        `<button class="page-num${active ? " active" : ""}" data-page="${p}">${p}</button>`;
      const navBtn = (label, p, cls, disabled) =>
        `<button class="${cls}" data-page="${p}" ${disabled ? "disabled" : ""}>${label}</button>`;

      items.push(navBtn("Previous", page - 1, "page-prev", page === 1));

      const pages = new Set([1, totalPages]);
      for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) pages.add(p);
      let prev = 0;
      for (const p of [...pages].sort((a, b) => a - b)) {
        if (prev && p - prev > 1) items.push(`<span class="page-ellipsis">…</span>`);
        items.push(numBtn(p, p === page));
        prev = p;
      }

      items.push(navBtn("Next", page + 1, "page-next", page === totalPages));
      paginationEl.innerHTML = items.join("");

      paginationEl.querySelectorAll("[data-page]:not([disabled])").forEach((b) => {
        b.addEventListener("click", () => {
          currentPage = parseInt(b.dataset.page, 10);
          applyView();
          table.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });
    }

    // ── Main view update ──────────────────────────────────────────────────────

    function applyView() {
      const filtered = getFilteredRows();
      const sorted   = sortRows(filtered);
      const start    = (currentPage - 1) * PAGE_SIZE;
      const pageRows = new Set(sorted.slice(start, start + PAGE_SIZE));

      // Reorder rows in the DOM so the visible rows appear in sort order.
      // appendChild on an existing node moves it — iterating in sorted order
      // places each row at the end in sequence, producing a fully sorted tbody.
      const domOrder = sortCol ? sortRows(allRows) : allRows;
      for (const row of domOrder) tbody.appendChild(row);

      for (const row of allRows) row.hidden = !pageRows.has(row);

      if (countEl) {
        const from = Math.min(start + 1, filtered.length);
        const to   = Math.min(start + PAGE_SIZE, filtered.length);
        countEl.textContent = filtered.length
          ? `Showing ${from}–${to} of ${filtered.length} site${filtered.length !== 1 ? "s" : ""}`
          : "No results";
      }

      renderPagination(filtered.length, currentPage);

      const hasFilter = activeCmsFilter || activeCmsTypeFilter || searchInput.value || noAstroOnly;
      if (clearBtn) clearBtn.hidden = !hasFilter;
    }

    // ── Filter controls ───────────────────────────────────────────────────────

    function clearTypeFilters() {
      document.querySelectorAll(".bar-filter-btn").forEach((b) => b.classList.remove("active"));
      if (starlightFilterBtn)  starlightFilterBtn.classList.remove("active");
      if (frameworkFilterBtn)  frameworkFilterBtn.classList.remove("active");
      if (forwardedFilterBtn)  forwardedFilterBtn.classList.remove("active");
      if (parkedFilterBtn)     parkedFilterBtn.classList.remove("active");
      forwardedOnly = false;
      parkedOnly = false;
    }

    function setCmsFilter(cms) {
      activeCmsFilter    = activeCmsFilter === cms ? null : cms;
      activeCmsTypeFilter = null;
      currentPage = 1;
      clearTypeFilters();
      document.querySelectorAll(".bar-filter-btn").forEach((b) =>
        b.classList.toggle("active", b.dataset.cms === activeCmsFilter)
      );
      if (starlightFilterBtn) starlightFilterBtn.classList.toggle("active", activeCmsFilter === "Starlight");
      applyView();
    }

    function setCmsTypeFilter(type, btn) {
      const isActive = activeCmsTypeFilter === type;
      activeCmsTypeFilter = isActive ? null : type;
      activeCmsFilter = null;
      currentPage = 1;
      clearTypeFilters();
      btn.classList.toggle("active", !isActive);
      applyView();
    }

    document.querySelectorAll(".bar-filter-btn").forEach((b) =>
      b.addEventListener("click", () => setCmsFilter(b.dataset.cms))
    );
    if (starlightFilterBtn) starlightFilterBtn.addEventListener("click", () => setCmsFilter("Starlight"));
    if (frameworkFilterBtn) frameworkFilterBtn.addEventListener("click", () => setCmsTypeFilter("framework", frameworkFilterBtn));
    if (forwardedFilterBtn) forwardedFilterBtn.addEventListener("click", () => {
      clearTypeFilters();
      forwardedOnly = !forwardedOnly;
      activeCmsFilter = null;
      activeCmsTypeFilter = null;
      currentPage = 1;
      forwardedFilterBtn.classList.toggle("active", forwardedOnly);
      applyView();
    });
    if (parkedFilterBtn) parkedFilterBtn.addEventListener("click", () => {
      clearTypeFilters();
      parkedOnly = !parkedOnly;
      activeCmsFilter = null;
      activeCmsTypeFilter = null;
      currentPage = 1;
      parkedFilterBtn.classList.toggle("active", parkedOnly);
      applyView();
    });

    if (astroFilterBtn) {
      astroFilterBtn.addEventListener("click", () => {
        noAstroOnly = !noAstroOnly;
        currentPage = 1;
        astroFilterBtn.classList.toggle("active", noAstroOnly);
        applyView();
      });
    }

    searchInput.addEventListener("input", () => { currentPage = 1; applyView(); });

    if (clearBtn) {
      clearBtn.addEventListener("click", () => {
        activeCmsFilter = null;
        activeCmsTypeFilter = null;
        forwardedOnly = false;
        parkedOnly = false;
        noAstroOnly = false;
        currentPage = 1;
        searchInput.value = "";
        clearTypeFilters();
        if (astroFilterBtn) astroFilterBtn.classList.remove("active");
        applyView();
      });
    }

    applyView();
  }

  initDetector();
  document.addEventListener("astro:page-load", initDetector);
</script>

<style>
  .page-header h1 { font-size: var(--step-3); line-height: 1.1; padding-block: var(--space-s); }
  .muted { color: var(--color-text-subtle); font-weight: 400; }
  .about-lead {
    font-size: var(--step-0);
    max-width: 68ch;
  }
  .about-lead a { color: var(--color-primary); }
  .submit-cta { font-size: var(--step--1); }
  .submit-cta a { color: var(--color-primary); font-weight: 500; }
  .meta-line { color: var(--color-text-subtle); font-size: var(--step--1); }
  .notice { font-style: italic; color: var(--color-text-subtle); }
  code { font-family: monospace; background: var(--color-surface); padding: 0.1em 0.4em; border-radius: 4px; }

  .about-details {
    border: 1px solid var(--gray-2);
    border-radius: var(--space-3xs);
    background: var(--color-surface);
    max-width: 68ch;
  }
  .about-details summary {
    padding: var(--space-xs) var(--space-s);
    font-size: var(--step--1);
    font-weight: 600;
    cursor: pointer;
    color: var(--color-text-subtle);
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }
  .about-details summary::before {
    content: "▶";
    font-size: 0.6em;
    transition: transform 0.15s;
  }
  .about-details[open] summary::before { transform: rotate(90deg); }
  .about-details summary:hover { color: var(--color-text); }
  .about-body {
    padding: var(--space-xs) var(--space-s) var(--space-s);
    border-top: 1px solid var(--gray-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-size: var(--step--1);
    color: var(--color-text-subtle);
  }
  .about-body a { color: var(--color-primary); }
  .about-body strong { color: var(--color-text); }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: var(--space-s);
  }
  .stat-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding: var(--space-s);
    border-radius: var(--space-3xs);
    background: var(--color-surface);
    border-left: 4px solid var(--gray-4);
  }
  .stat-card--astro    { border-color: var(--violet-6); }
  .stat-card--migrated { border-color: var(--orange-5); }
  .stat-card--detected { border-color: var(--blue-6); }
  .stat-card--parked   { border-color: var(--yellow-5); }
  .stat-card--error    { border-color: var(--red-5); }
  .stat-value { font-size: var(--step-3); font-weight: 700; line-height: 1; }
  .stat-label { font-size: var(--step--1); color: var(--color-text-subtle); }

  .breakdown h2 { font-size: var(--step-1); }
  .bar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 3;
    column-gap: var(--space-xl);
  }
  .bar-list li {
    break-inside: avoid;
    border-bottom: 1px solid var(--gray-2);
  }
  .bar-list li:last-child { border-bottom: none; }
  @media (max-width: 900px) { .bar-list { columns: 2; } }
  @media (max-width: 540px) { .bar-list { columns: 1; } }
  .bar-filter-btn {
    display: grid;
    grid-template-columns: 10rem 1fr 2.5rem;
    align-items: center;
    gap: var(--space-2xs);
    width: 100%;
    background: none;
    border: 2px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    padding: var(--space-3xs);
    padding-inline-start: 0;
    color: inherit;
    text-align: left;
  }
  .bar-filter-btn:hover .bar-fill { opacity: 0.75; }
  .bar-filter-btn.active { border-color: var(--color-primary);
     background: var(--blue-0); }
  .bar-track { height: 1.25rem; background: var(--gray-2);
     border-radius: 3px; overflow: hidden; }
  .bar-fill { display: block; height: 100%; background: var(--color-primary);
     border-radius: 3px; min-width: 2px; }
  .bar-index {
    font-size: var(--step--2);
    color: var(--gray-4);
    font-variant-numeric: tabular-nums;
    min-width: 1.5em;
    text-align: right;
  }
  .bar-count { font-size: var(--step--1); color: var(--color-text-subtle); text-align: right; }

  .cms-badge {
    display: inline-block;
    padding: 0.15em 0.6em;
    border-radius: 999px;
    font-size: var(--step--2);
    font-weight: 600;
    white-space: nowrap;
    background: var(--gray-2);
    color: var(--gray-8);
  }
  .cms-badge--headless-cms { background: var(--blue-1);   color: var(--blue-9); }
  .cms-badge--page-builder { background: var(--purple-1); color: var(--purple-9); }
  .cms-badge--full-site    { background: var(--red-1);    color: var(--red-9); }
  .cms-badge--framework    { background: var(--cyan-1);   color: var(--cyan-9); }
  .cms-badge--static-gen   { background: var(--green-1);  color: var(--green-9); }
  .cms-badge--parked       { background: var(--yellow-1); color: var(--yellow-9); }

  .results-count { font-size: var(--step--1); color: var(--color-text-subtle); }
</style>
