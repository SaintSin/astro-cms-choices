---
// src/pages/crux.astro
// 2026-06-10T12:00:00Z

import ShowcasePagination from "@components/showcase/ShowcasePagination.astro";
import Layout from "@layouts/BaseLayout.astro";
import Database from "better-sqlite3";

const meta = {
	title: "Core Web Vitals — Astro CMS Detector",
	description:
		"Real-user Chrome UX Report performance data for confirmed Astro sites across desktop, phone, and tablet.",
	imageOG: "og-crux.png",
	altOG:
		"Core Web Vitals — 514 desktop sites, 382 Desktop CWV pass, 253 Phone CWV pass",
};

let sites: any[] = [];
let generatedAt = "";
let totalWithData = 0;
let desktopCount = 0;
let phoneCount = 0;
let tabletCount = 0;
let desktopCwvPass = 0;
let phoneCwvPass = 0;

try {
	const db = new Database(".scan-history.db", { readonly: true });
	const run = db
		.prepare("SELECT id, started_at FROM crux_runs ORDER BY id DESC LIMIT 1")
		.get() as { id: number; started_at: string };
	const latestScan = db
		.prepare("SELECT id FROM scans ORDER BY id DESC LIMIT 1")
		.get() as { id: number };

	generatedAt = run.started_at;

	sites = db
		.prepare(
			`WITH latest_ff AS (
        SELECT site_id, form_factor, MAX(run_id) AS run_id
        FROM crux_results WHERE status = 'success'
        GROUP BY site_id, form_factor
      )
      SELECT
        s.hostname, s.url,
        sr.title, sr.astro_version,
        MAX(CASE WHEN cr.form_factor='DESKTOP' THEN cr.lcp_p75 END)    as d_lcp,
        MAX(CASE WHEN cr.form_factor='DESKTOP' THEN cr.inp_p75 END)    as d_inp,
        MAX(CASE WHEN cr.form_factor='DESKTOP' THEN cr.cls_p75 END)    as d_cls,
        MAX(CASE WHEN cr.form_factor='DESKTOP' THEN cr.lcp_rating END) as d_lcp_r,
        MAX(CASE WHEN cr.form_factor='DESKTOP' THEN cr.inp_rating END) as d_inp_r,
        MAX(CASE WHEN cr.form_factor='DESKTOP' THEN cr.cls_rating END) as d_cls_r,
        MAX(CASE WHEN cr.form_factor='DESKTOP' THEN cr.cwv_pass END)   as d_cwv,
        MAX(CASE WHEN cr.form_factor='PHONE' THEN cr.lcp_p75 END)      as p_lcp,
        MAX(CASE WHEN cr.form_factor='PHONE' THEN cr.inp_p75 END)      as p_inp,
        MAX(CASE WHEN cr.form_factor='PHONE' THEN cr.cls_p75 END)      as p_cls,
        MAX(CASE WHEN cr.form_factor='PHONE' THEN cr.lcp_rating END)   as p_lcp_r,
        MAX(CASE WHEN cr.form_factor='PHONE' THEN cr.inp_rating END)   as p_inp_r,
        MAX(CASE WHEN cr.form_factor='PHONE' THEN cr.cls_rating END)   as p_cls_r,
        MAX(CASE WHEN cr.form_factor='PHONE' THEN cr.cwv_pass END)     as p_cwv,
        MAX(CASE WHEN cr.form_factor='TABLET' THEN cr.lcp_p75 END)     as t_lcp,
        MAX(CASE WHEN cr.form_factor='TABLET' THEN cr.inp_p75 END)     as t_inp,
        MAX(CASE WHEN cr.form_factor='TABLET' THEN cr.cls_p75 END)     as t_cls,
        MAX(CASE WHEN cr.form_factor='TABLET' THEN cr.lcp_rating END)  as t_lcp_r,
        MAX(CASE WHEN cr.form_factor='TABLET' THEN cr.inp_rating END)  as t_inp_r,
        MAX(CASE WHEN cr.form_factor='TABLET' THEN cr.cls_rating END)  as t_cls_r,
        MAX(CASE WHEN cr.form_factor='TABLET' THEN cr.cwv_pass END)    as t_cwv
      FROM latest_ff lf
      JOIN crux_results cr ON cr.site_id = lf.site_id
        AND cr.form_factor = lf.form_factor AND cr.run_id = lf.run_id
      JOIN sites s ON s.id = cr.site_id
      JOIN scan_results sr ON sr.site_id = s.id AND sr.scan_id = ?
        AND sr.astro_detected = 1
      GROUP BY s.id
      HAVING d_lcp IS NOT NULL OR p_lcp IS NOT NULL OR t_lcp IS NOT NULL
      ORDER BY s.hostname`,
		)
		.all(latestScan.id) as any[];

	totalWithData = sites.length;
	desktopCount = sites.filter((s) => s.d_lcp !== null).length;
	phoneCount = sites.filter((s) => s.p_lcp !== null).length;
	tabletCount = sites.filter((s) => s.t_lcp !== null).length;
	desktopCwvPass = sites.filter((s) => s.d_cwv === 1).length;
	phoneCwvPass = sites.filter((s) => s.p_cwv === 1).length;

	db.close();
} catch (e) {
	console.warn("CrUX DB not available:", e);
}

function fmtLcp(ms: number | null) {
	if (ms === null) return null;
	return (ms / 1000).toFixed(1) + "s";
}
function fmtInp(ms: number | null) {
	if (ms === null) return null;
	return ms + "ms";
}
function fmtCls(v: number | null) {
	if (v === null) return null;
	return v.toFixed(3);
}
---

<Layout metaData={meta}>
  <main class="wrapper flow">
    <header class="page-header flow">
      <h1>Core Web Vitals <span class="muted">Real-user data</span></h1>
      <p class="page-lead">
        28-day <a href="https://developer.chrome.com/docs/crux" target="_blank" rel="noopener noreferrer">Chrome UX Report</a> field data for confirmed Astro sites.
        Data collected {new Date(generatedAt).toLocaleDateString("en-GB", { dateStyle: "medium" })}.
        Only sites with sufficient Chrome traffic appear ({totalWithData.toLocaleString()} of ~2,100 confirmed Astro sites).
      </p>
    </header>

    <div class="stats-row">
      <div class="stat-card">
        <span class="stat-value">{desktopCount}</span>
        <span class="stat-label">Desktop</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">{phoneCount}</span>
        <span class="stat-label">Phone</span>
      </div>
      <div class="stat-card stat-card--muted">
        <span class="stat-value">{tabletCount}</span>
        <span class="stat-label">Tablet</span>
      </div>
      <div class="stat-card stat-card--pass">
        <span class="stat-value">{desktopCwvPass}</span>
        <span class="stat-label">Desktop CWV pass</span>
      </div>
      <div class="stat-card stat-card--pass">
        <span class="stat-value">{phoneCwvPass}</span>
        <span class="stat-label">Phone CWV pass</span>
      </div>
    </div>



    <div class="toolbar">
      <input
        type="search"
        id="crux-search"
        class="search-input"
        placeholder="Filter by site name or URL…"
        autocomplete="off"
      />
      <span class="result-count" id="result-count">{totalWithData} sites</span>
    </div>

    <div class="table-wrap" id="crux-table-wrap">
      <table class="crux-table data-table" id="crux-table">
        <colgroup>
          <col class="col-site" />
          <col class="col-ver" />
          <col class="col-lcp" /><col class="col-inp" /><col class="col-cls" /><col class="col-cwv" />
          <col class="col-lcp" /><col class="col-inp" /><col class="col-cls" /><col class="col-cwv" />
          <col class="col-lcp" /><col class="col-inp" /><col class="col-cls" /><col class="col-cwv" />
        </colgroup>
        <thead>
          <tr>
            <th class="sortable col-site" data-col="title">Site</th>
            <th class="sortable col-ver" data-col="version">Astro</th>
            <th class="col-group-header" colspan="4">
            Desktop
            </th>
            <th class="col-group-header" colspan="4">
              Phone
            </th>
            <th class="col-group-header" colspan="4">
            Tablet
            </th>
          </tr>
          <tr class="subheader">
            <th></th>
            <th></th>
            <th class="sortable metric-th col-lcp" data-col="d_lcp">LCP</th>
            <th class="sortable metric-th col-inp" data-col="d_inp">INP</th>
            <th class="sortable metric-th col-cls" data-col="d_cls">CLS</th>
            <th class="sortable metric-th col-cwv" data-col="d_cwv">CWV</th>
            <th class="sortable metric-th col-lcp" data-col="p_lcp">LCP</th>
            <th class="sortable metric-th col-inp" data-col="p_inp">INP</th>
            <th class="sortable metric-th col-cls" data-col="p_cls">CLS</th>
            <th class="sortable metric-th col-cwv" data-col="p_cwv">CWV</th>
            <th class="sortable metric-th col-lcp" data-col="t_lcp">LCP</th>
            <th class="sortable metric-th col-inp" data-col="t_inp">INP</th>
            <th class="sortable metric-th col-cls" data-col="t_cls">CLS</th>
            <th class="sortable metric-th col-cwv" data-col="t_cwv">CWV</th>
          </tr>
        </thead>
        <tbody id="crux-tbody">
          {sites.map((s) => (
            <tr
              data-title={(s.title ?? s.hostname).toLowerCase()}
              data-url={s.url.toLowerCase()}
              data-version={s.astro_version ?? ""}
              data-d_lcp={s.d_lcp ?? ""}
              data-d_inp={s.d_inp ?? ""}
              data-d_cls={s.d_cls ?? ""}
              data-d_cwv={s.d_cwv ?? ""}
              data-p_lcp={s.p_lcp ?? ""}
              data-p_inp={s.p_inp ?? ""}
              data-p_cls={s.p_cls ?? ""}
              data-p_cwv={s.p_cwv ?? ""}
              data-t_lcp={s.t_lcp ?? ""}
              data-t_inp={s.t_inp ?? ""}
              data-t_cls={s.t_cls ?? ""}
              data-t_cwv={s.t_cwv ?? ""}
            >
              <td class="col-site">
                <a href={s.url} target="_blank" rel="noopener noreferrer">
                  {s.title ?? s.hostname}
                </a>
              </td>
              <td class="col-ver">
                {s.astro_version ? <span class="ver-badge">v{s.astro_version}</span> : <span class="no-data">—</span>}
              </td>
              <!-- Desktop -->
              <td class={`metric col-lcp ${s.d_lcp_r ?? "none"}`}>{fmtLcp(s.d_lcp) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-inp ${s.d_inp_r ?? "none"}`}>{fmtInp(s.d_inp) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-cls ${s.d_cls_r ?? "none"}`}>{fmtCls(s.d_cls) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-cwv cwv ${s.d_cwv === 1 ? "good" : s.d_cwv === 0 ? "poor" : "none"}`}>
                {s.d_cwv === 1 ? "✓" : s.d_cwv === 0 ? "✗" : <span class="no-data">—</span>}
              </td>
              <!-- Phone -->
              <td class={`metric col-lcp ${s.p_lcp_r ?? "none"}`}>{fmtLcp(s.p_lcp) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-inp ${s.p_inp_r ?? "none"}`}>{fmtInp(s.p_inp) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-cls ${s.p_cls_r ?? "none"}`}>{fmtCls(s.p_cls) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-cwv cwv ${s.p_cwv === 1 ? "good" : s.p_cwv === 0 ? "poor" : "none"}`}>
                {s.p_cwv === 1 ? "✓" : s.p_cwv === 0 ? "✗" : <span class="no-data">—</span>}
              </td>
              <!-- Tablet -->
              <td class={`metric col-lcp ${s.t_lcp_r ?? "none"}`}>{fmtLcp(s.t_lcp) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-inp ${s.t_inp_r ?? "none"}`}>{fmtInp(s.t_inp) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-cls ${s.t_cls_r ?? "none"}`}>{fmtCls(s.t_cls) ?? <span class="no-data">—</span>}</td>
              <td class={`metric col-cwv cwv ${s.t_cwv === 1 ? "good" : s.t_cwv === 0 ? "poor" : "none"}`}>
                {s.t_cwv === 1 ? "✓" : s.t_cwv === 0 ? "✗" : <span class="no-data">—</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <ShowcasePagination id="crux-pagination" />
        <aside class="callout">
      <strong>Why is tablet data sparse?</strong>
      CrUX only records data from Chrome users who have opted in to sync.
      Tablets are dominated by iPad + Safari — Chrome on iOS uses Apple's WebKit engine
      and has no telemetry access, and Safari usage simply doesn't appear in CrUX at all.
      Missing tablet data reflects iPad/Safari dominance, not low traffic.
    </aside>
  </main>
</Layout>

<script is:inline>
  function initCrux() {
    const tbody = document.getElementById("crux-tbody");
    const searchEl = document.getElementById("crux-search");
    const countEl = document.getElementById("result-count");
    const paginationEl = document.getElementById("crux-pagination");
    const tableWrap = document.getElementById("crux-table-wrap");
    if (!tbody || !searchEl || !countEl || !paginationEl) return;

    const PAGE_SIZE = 50;
    const allRows = Array.from(tbody.querySelectorAll("tr"));
    let sortCol = null;
    let sortAsc = true;
    let currentPage = 1;

    // data-d_lcp → dataset.d_lcp (underscores preserved by dataset API)
    function numVal(row, col) {
      const v = row.dataset[col];
      return v === "" || v === undefined ? Infinity : parseFloat(v);
    }

    function sortRows(rows) {
      if (!sortCol) return rows;
      return [...rows].sort((a, b) => {
        let cmp;
        if (sortCol === "title") {
          cmp = (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "");
        } else if (sortCol === "version") {
          const av = a.dataset.version, bv = b.dataset.version;
          if (!av && !bv) return 0;
          if (!av) return 1;
          if (!bv) return -1;
          cmp = av.localeCompare(bv, undefined, { numeric: true });
          return sortAsc ? cmp : -cmp;
        } else if (sortCol.endsWith("cwv")) {
          const va = numVal(a, sortCol), vb = numVal(b, sortCol);
          // pass (1) first, fail (0) second, no-data (Infinity) last — always
          const ra = va === Infinity ? 2 : va === 1 ? 0 : 1;
          const rb = vb === Infinity ? 2 : vb === 1 ? 0 : 1;
          cmp = ra - rb;
          return sortAsc ? cmp : -cmp;
        } else {
          // LCP / INP / CLS — no-data always last regardless of direction
          const va = numVal(a, sortCol), vb = numVal(b, sortCol);
          const aEmpty = va === Infinity, bEmpty = vb === Infinity;
          if (aEmpty && bEmpty) return 0;
          if (aEmpty) return 1;
          if (bEmpty) return -1;
          cmp = va - vb;
        }
        return sortAsc ? cmp : -cmp;
      });
    }

    function getFiltered() {
      const query = searchEl.value.toLowerCase().trim();
      return allRows.filter(r =>
        !query || r.dataset.title.includes(query) || r.dataset.url.includes(query)
      );
    }

    function applyView() {
      const filtered = getFiltered();
      const sorted = sortRows(filtered);
      const start = (currentPage - 1) * PAGE_SIZE;
      const pageSet = new Set(sorted.slice(start, start + PAGE_SIZE));

      const domOrder = sortCol ? sortRows(allRows) : allRows;
      for (const row of domOrder) tbody.appendChild(row);
      for (const row of allRows) row.hidden = !pageSet.has(row);

      const from = Math.min(start + 1, filtered.length);
      const to = Math.min(start + PAGE_SIZE, filtered.length);
      countEl.textContent = filtered.length
        ? `Showing ${from}–${to} of ${filtered.length} site${filtered.length !== 1 ? "s" : ""}`
        : "No results";

      renderPagination(paginationEl, filtered.length, currentPage, PAGE_SIZE, (p) => {
        currentPage = p;
        applyView();
        tableWrap?.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      document.querySelectorAll(".sortable").forEach(th => {
        const col = th.dataset.col;
        th.classList.toggle("sort-asc", sortCol === col && sortAsc);
        th.classList.toggle("sort-desc", sortCol === col && !sortAsc);
      });
    }

    searchEl.addEventListener("input", () => { currentPage = 1; applyView(); });

    document.querySelectorAll(".sortable").forEach(th => {
      th.addEventListener("click", () => {
        const col = th.dataset.col;
        if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
        currentPage = 1;
        applyView();
      });
    });

    applyView();
  }

  initCrux();
  document.addEventListener("astro:page-load", initCrux);
</script>

<style>

  .col-group-header { width: 25ch; }

  /* Device group separators — Desktop starts at col 3, Phone at 7, Tablet at 11 */
  .crux-table td:nth-child(3),
  .crux-table td:nth-child(7),
  .crux-table td:nth-child(11),
  .crux-table .subheader th:nth-child(3),
  .crux-table .subheader th:nth-child(7),
  .crux-table .subheader th:nth-child(11) {
    border-inline-start: 2px solid var(--gray-3);
  }

  .col-site { width: 28ch; overflow: hidden; text-overflow: ellipsis; }

  .col-ver { width: 8ch; }

  /* Fixed widths prevent layout shift when sorting changes values per row */
  .col-lcp { width: 6ch; }
  .col-inp { width: 7ch; }
  .col-cls { width: 7ch; }
  .col-cwv { width: 5ch; }
  .crux-table th.col-cwv,
  .crux-table td.col-cwv {
    padding-inline-end: var(--space-xs);
    font-size: var(--step--2);
  }

  .metric-th { text-align: center; }

</style>
