---
// src/components/global/Footer.astro
// 2026-06-11T00:00:00Z

const year = new Date().getUTCFullYear();
---

<footer class="footer">
  <div class="wrapper">
    <span class="copyright">&copy;&nbsp;{year}</span>
    <div class="footer-right">
      <a
        href="https://www.netlify.com"
        target="_blank"
        rel="noopener noreferrer"
        class="badge-link"
        aria-label="Hosted by Netlify"
      >
        <img
          src="https://www.netlify.com/img/global/badges/netlify-color-accent.svg"
          alt="Hosted by Netlify"
          height="30"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="badge-link"
        aria-label="Built with Astro"
      >
        <img
          src="https://astro.badg.es/v2/built-with-astro/small.svg"
          alt="Built with Astro"
          height="30"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href="https://github.com/SaintSin/astro-cms-choices"
        target="_blank"
        rel="noopener noreferrer"
        class="github-link"
        aria-label="View source on GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="27" height="27" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.744 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</footer>
<style>
  .footer {
    margin-block-start: var(--space-l);
    background: var(--color-surface);
    padding-block: var(--space-xs);
  }
  .footer .wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .copyright {
    font-size: var(--step--1);
    color: var(--color-text-subtle);
  }
  .footer-right {
    display: flex;
    align-items: center;
    gap: var(--space-s);
  }
  .badge-link {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    opacity: 0.75;
    transition: opacity 0.12s ease;
  }
  .badge-link:hover { opacity: 1; }
  .badge-link img { display: block; height: 30px; width: auto; }
  .github-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3xs);
    color: var(--color-text-subtle);
    text-decoration: none;
    font-size: var(--step--1);
    line-height: 1;
    transition: color 0.12s ease;
  }
  .github-link:hover { color: var(--color-text); }
</style>
