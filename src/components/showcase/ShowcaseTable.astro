---
// src/components/showcase/ShowcaseTable.astro
// 2026-05-17T00:00:00Z

import type { CmsResult } from "../../types/index";
import ShowcaseRow from "./ShowcaseRow.astro";

interface Props {
	results: CmsResult[];
	pageSize: number;
}

const { results, pageSize } = Astro.props;
// Only the first page is rendered into the live DOM (fast initial paint, small
// tree). The rest sits inert inside a <template> — parsed but never laid out
// or style-computed until JS clones rows out of it for later pages.
const firstPage = results.slice(0, pageSize);
const restRows = results.slice(pageSize);
---

<div class="table-wrap">
  <table class="results-table data-table" id="results-table" data-page-size={pageSize}>
    <colgroup>
      <col class="col-site" />
      <col class="col-astro" />
      <col class="col-cms" />
      <col class="col-type" />
      <col class="col-conf" />
    </colgroup>
    <thead>
      <tr>
        <th scope="col" class="sortable" data-col="title">Site</th>
        <th scope="col" class="sortable" data-col="astro">Astro version</th>
        <th scope="col" class="sortable" data-col="cms">CMS</th>
        <th scope="col" class="sortable" data-col="cmstype">Type</th>
        <th scope="col">Conf.</th>
      </tr>
    </thead>
    <tbody id="results-tbody">
      {firstPage.map((r) => <ShowcaseRow r={r} />)}
    </tbody>
  </table>
</div>

<template id="all-rows-template">
  {restRows.map((r) => <ShowcaseRow r={r} />)}
</template>

<p class="table-key">
  <span class="key-swatch key-swatch--migrated"></span>
  <span class="key-label">Full-site CMS — site appears to have migrated away from Astro</span>
</p>

<style>
  .col-site  { width: 35ch; }
  .col-astro { width: 14ch; }
  .col-cms   { width: 16ch; }
  .col-type  { width: 18ch; }
  .col-conf  { width: 7ch;  }

  .table-key {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    margin-block-start: var(--space-xs);
    font-size: var(--step--2);
    color: var(--color-text-subtle);
  }
  .key-swatch {
    display: inline-block;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .key-swatch--migrated { background: var(--orange-0); border: 1px solid var(--orange-2); }
</style>
