{
	"name": "astro60",
	"version": "0.0.1",
	"author": "St John Mackay",
	"contributors": [
		{
			"name": "Claude (Anthropic)",
			"url": "https://claude.ai"
		}
	],
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check --write .",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"detect": "node --experimental-strip-types scripts/detect-cms.ts",
		"db:init": "node --experimental-strip-types scripts/db-init.ts",
		"db:report": "node --experimental-strip-types scripts/db-report.ts",
		"psi": "node scripts/psi.mjs",
		"crux": "node scripts/crux.mjs",
		"clean": "rm -rf dist .astro",
		"purge": "rm -rf dist .astro .netlify node_modules",
		"deploy": "netlify deploy --prod --dir dist --functions netlify/functions",
		"deploy:draft": "netlify deploy --dir dist --functions netlify/functions"
	},
	"dependencies": {
		"@astrojs/compiler-rs": "^0.2.1",
		"@astrojs/sitemap": "^3.7.3",
		"@felixicaza/astro-capo": "^1.2.1",
		"@iconify-json/ri": "^1.2.10",
		"astro": "^6.4.5",
		"astro-iconify": "^1.3.1",
		"astro-robots-txt": "^1.0.0",
		"chart.js": "^4.5.1",
		"i": "^0.3.7",
		"open-props": "^1.7.23",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@netlify/functions": "^5.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.10.0",
		"fallow": "^2.91.0",
		"oxfmt": "^0.54.0",
		"postcss-jit-props": "^1.0.16"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
