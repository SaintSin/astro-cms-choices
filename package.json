{
	"name": "astro60",
	"version": "0.0.1",
	"author": "St John Mackay",
	"contributors": [
		{
			"name": "Claude (Anthropic)",
			"url": "https://claude.ai"
		}
	],
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check --write .",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"detect": "node --experimental-strip-types scripts/detect-cms.ts",
		"db:init": "node --experimental-strip-types scripts/db-init.ts",
		"db:report": "node --experimental-strip-types scripts/db-report.ts",
		"psi": "node scripts/psi.mjs",
		"crux": "node scripts/crux.mjs",
		"dns-check": "node scripts/dns-check.mjs",
		"make-prs": "node scripts/make-removal-prs.mjs",
		"generate:og-cards": "node scripts/generate-og-cards.mjs",
		"clean": "rm -rf dist .astro",
		"purge": "rm -rf dist .astro .netlify node_modules",
		"deploy": "netlify deploy --prod --dir dist --functions netlify/functions",
		"deploy:draft": "netlify deploy --dir dist --functions netlify/functions"
	},
	"dependencies": {
		"@astrojs/compiler-rs": "^0.3.1",
		"@astrojs/sitemap": "^3.7.3",
		"@felixicaza/astro-capo": "^1.2.1",
		"@iconify-json/ri": "^1.2.10",
		"astro": "^7.1.0",
		"astro-iconify": "^1.3.1",
		"astro-llms-md": "^2.2.2",
		"astro-robots-txt": "^1.0.0",
		"chart.js": "^4.5.1",
		"i": "^0.3.7",
		"open-props": "^1.7.23",
		"sharp": "^0.35.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@netlify/functions": "^5.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.11.1",
		"oxfmt": "^0.59.0",
		"playwright": "^1.61.1",
		"postcss-jit-props": "^1.0.16"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
}
